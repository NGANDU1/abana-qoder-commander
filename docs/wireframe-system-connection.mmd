  %% Smart Waste Management System — Connection Wireframe

  PU["Public User (Reporter)"]
  DR["Worker/Driver (Collector)"]
  AD["Admin (Operator)"]

  APP["Web Application (Flask)\nUI + Controllers + Business Logic"]
  AUTH["Authentication & Roles\n(Admin/Worker/Public)"]
  BINMON["Bin Monitoring\nFill level + thresholds\nSensor readings"]
  ALERTS["Alerts & Notifications\nFull/Overflow alerts\nNotification logs"]
  ROUTE["Route Optimization\nUrgency-weighted greedy\nRoutes + stops"]

  DB["Database (MySQL/SQLite)\nusers, bins, sensor_readings, alerts,\nnotification_logs, routes, route_stops,\ncollection_events, bin_reports"]
  IOT["IoT Data Source\n(Admin simulator ticks)\nOR /api/sensor/update"]
  MAP["Maps\nLeaflet + OSM tiles\nLive GPS user location"]

  PU --> APP
  DR --> APP
  AD --> APP

  APP --> AUTH
  APP --> BINMON
  APP --> ALERTS
  APP --> ROUTE

  AUTH --> DB
  BINMON --> DB
  ALERTS --> DB
  ROUTE --> DB

  IOT -. sensor updates .-> APP
  MAP -. tiles + GPS .-> APP

